<!DOCTYPE html>
<html>
  <head>
    <title>App</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <header class="bg-white shadow-sm" data-controller="nav-toggle">
      <nav class="container mx-auto px-5 py-4 flex items-center justify-between">
        <%= link_to "合格ペース管理アプリ", root_path, class: "text-lg font-bold text-gray-900 shrink-0" %>

        <%# デスクトップ nav %>
        <div class="hidden sm:flex items-center gap-4 text-sm">
          <% if user_signed_in? %>
            <%= link_to "ホーム", root_path, class: "text-gray-600 hover:text-blue-600 transition" %>
            <% if current_certification %>
              <%= link_to "進捗", certification_study_logs_path(current_certification), class: "text-gray-600 hover:text-blue-600 transition" %>
            <% end %>
            <%= link_to "マイページ", mypage_path, class: "text-gray-600 hover:text-blue-600 transition" %>
            <span class="text-gray-300">|</span>
            <span class="text-gray-500"><%= current_user.name %> さん</span>
            <%= button_to "ログアウト", destroy_user_session_path, method: :delete,
                class: "text-gray-600 hover:text-blue-600 cursor-pointer" %>
          <% else %>
            <%= link_to "ログイン", new_user_session_path, class: "text-gray-600 hover:text-blue-600 transition" %>
            <%= link_to "新規登録", new_user_registration_path,
                class: "bg-blue-600 text-white font-semibold py-2 px-4 rounded-md hover:bg-blue-700 transition" %>
          <% end %>
        </div>

        <%# モバイル ハンバーガーボタン %>
        <button class="sm:hidden flex flex-col justify-center items-center w-8 h-8 gap-1.5 text-gray-600"
                data-action="click->nav-toggle#toggle" aria-label="メニュー">
          <span class="block w-6 h-0.5 bg-current"></span>
          <span class="block w-6 h-0.5 bg-current"></span>
          <span class="block w-6 h-0.5 bg-current"></span>
        </button>
      </nav>

      <%# モバイル ドロップダウン %>
      <div class="sm:hidden hidden border-t border-gray-100 bg-white px-5 py-4 flex flex-col gap-3 text-sm"
           data-nav-toggle-target="menu">
        <% if user_signed_in? %>
          <%= link_to "ホーム", root_path, class: "text-gray-700 hover:text-blue-600 py-1" %>
          <% if current_certification %>
            <%= link_to "進捗", certification_study_logs_path(current_certification), class: "text-gray-700 hover:text-blue-600 py-1" %>
          <% end %>
          <%= link_to "マイページ", mypage_path, class: "text-gray-700 hover:text-blue-600 py-1" %>
          <hr class="border-gray-100">
          <p class="text-gray-500 text-xs"><%= current_user.name %> さん</p>
          <%= button_to "ログアウト", destroy_user_session_path, method: :delete,
              class: "w-full text-left text-gray-700 hover:text-blue-600 cursor-pointer py-1" %>
        <% else %>
          <%= link_to "ログイン", new_user_session_path, class: "text-gray-700 hover:text-blue-600 py-1" %>
          <%= link_to "新規登録", new_user_registration_path, class: "text-gray-700 hover:text-blue-600 py-1" %>
        <% end %>
      </div>
    </header>

    <% if notice %>
      <p class="py-2 px-3 bg-green-50 text-green-500 font-medium rounded-lg inline-block" id="notice"><%= notice %></p>
    <% end %>
    <% if alert %>
      <p class="py-2 px-3 bg-red-50 text-red-500 font-medium rounded-lg inline-block" id="alert"><%= alert %></p>
    <% end %>
    <main class="container mx-auto mt-12 px-5 flex">
      <%= yield %>
    </main>

    <footer class="mt-16 border-t bg-white">
      <div class="container mx-auto px-5 py-6 flex flex-col sm:flex-row items-center justify-between gap-2 text-sm text-gray-400">
        <p>&copy; 2026 合格ペース管理アプリ</p>
        <nav class="flex gap-4">
          <%= link_to "利用規約", terms_path, class: "hover:text-blue-600 transition" %>
          <%= link_to "プライバシーポリシー", privacy_policy_path, class: "hover:text-blue-600 transition" %>
        </nav>
      </div>
    </footer>
  </body>
</html>
