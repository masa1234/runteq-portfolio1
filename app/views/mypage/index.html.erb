<div class="w-full max-w-2xl mx-auto py-8">
  <h1 class="text-2xl font-bold text-gray-900 mb-6">マイページ</h1>

  <div class="bg-white rounded-lg shadow p-6 mb-6">
    <h2 class="text-lg font-semibold text-gray-900 mb-4">アカウント情報</h2>
    <dl class="space-y-2">
      <div class="flex">
        <dt class="w-32 text-sm text-gray-500">お名前</dt>
        <dd class="text-gray-900"><%= current_user.name %></dd>
      </div>
      <div class="flex">
        <dt class="w-32 text-sm text-gray-500">メールアドレス</dt>
        <dd class="text-gray-900"><%= current_user.email %></dd>
      </div>
    </dl>
  </div>

  <div class="bg-white rounded-lg shadow p-6 mb-6">
    <h2 class="text-lg font-semibold text-gray-900 mb-4">登録資格</h2>
    <% if @certification %>
      <p class="text-gray-900 mb-2"><%= @certification.name %></p>
      <%= link_to "ダッシュボードを見る", certification_path(@certification), class: "text-blue-600 hover:underline text-sm" %>
    <% else %>
      <p class="text-gray-500 mb-2">資格はまだ登録されていません。</p>
      <%= link_to "資格を登録する", new_certification_path,
          class: "inline-block bg-blue-600 text-white font-semibold py-2 px-4 rounded-md hover:bg-blue-700 transition text-sm" %>
    <% end %>
  </div>

  <%= button_to "ログアウト", destroy_user_session_path, method: :delete,
      class: "bg-gray-200 text-gray-700 font-semibold py-2 px-4 rounded-md hover:bg-gray-300 transition cursor-pointer" %>
</div>
