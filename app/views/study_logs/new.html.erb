<div class="w-full max-w-2xl mx-auto py-8">
  <h1 class="text-2xl font-bold text-gray-900 mb-1">学習を記録する</h1>
  <p class="text-sm text-gray-500 mb-6"><%= @certification.name %></p>

  <%= form_with model: [@certification, @study_log],
      class: "bg-white rounded-lg shadow p-6",
      data: { controller: "preset-minutes" } do |f| %>

    <%# バリデーションエラー %>
    <% if @study_log.errors.any? %>
      <div class="bg-red-50 border border-red-300 text-red-700 rounded-md px-4 py-3 mb-6">
        <p class="font-medium mb-1"><%= @study_log.errors.count %>件のエラーがあります</p>
        <ul class="list-disc list-inside text-sm space-y-0.5">
          <% @study_log.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%# 時間プリセットボタン %>
    <div class="mb-6">
      <p class="text-sm font-medium text-gray-700 mb-3">時間プリセット</p>
      <div class="flex gap-2 flex-wrap">
        <% [15, 30, 60, 90, 120].each do |min| %>
          <button type="button"
                  class="bg-gray-100 text-gray-700 font-semibold py-2 px-4 rounded-md hover:bg-blue-600 hover:text-white transition"
                  data-preset-minutes-target="preset"
                  data-action="click->preset-minutes#select"
                  data-preset-minutes-value-param="<%= min %>">
            <%= min %>分
          </button>
        <% end %>
      </div>
    </div>

    <%# 学習時間（手入力） %>
    <div class="mb-6">
      <%= f.label :studied_minutes, "学習時間（分）",
          class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.number_field :studied_minutes, min: 1,
          class: "w-full border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500",
          placeholder: "例: 45",
          data: { preset_minutes_target: "minutesInput" } %>
    </div>

    <%# 学習日 %>
    <div class="mb-6">
      <%= f.label :logged_on, "学習日",
          class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.date_field :logged_on,
          class: "w-full border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500" %>
    </div>

    <%# メモ（任意） %>
    <div class="mb-1">
      <%= f.label :memo, "メモ（任意）",
          class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_area :memo, rows: 3,
          class: "w-full border border-gray-300 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500 resize-none",
          placeholder: "例: 午前中に第3章を終えた。計算問題が難しかった。" %>
    </div>
    <p class="text-xs text-gray-400 mb-6">メモなしでも記録できます</p>

    <%= f.submit "記録する",
        class: "w-full bg-blue-600 text-white font-semibold py-3 px-6 rounded-md hover:bg-blue-700 transition cursor-pointer" %>
  <% end %>
</div>
