<div class="w-full max-w-2xl mx-auto py-8">
  <h1 class="text-2xl font-bold text-gray-900 mb-6"><%= @certification.name %></h1>

  <%# ペース判定バッジ %>
  <% pace = { on_track: { emoji: "🟢", label: "順調",  bg: "bg-green-50",  border: "border-green-200",  text: "text-green-800"  },
              caution:  { emoji: "🟡", label: "要注意", bg: "bg-yellow-50", border: "border-yellow-200", text: "text-yellow-800" },
              behind:   { emoji: "🔴", label: "遅れ",   bg: "bg-red-50",   border: "border-red-200",   text: "text-red-800"   } }[@certification.pace_status] %>
  <div class="<%= pace[:bg] %> border <%= pace[:border] %> rounded-lg p-5 mb-6 flex items-center gap-4">
    <span class="text-4xl leading-none"><%= pace[:emoji] %></span>
    <div>
      <p class="text-lg font-bold <%= pace[:text] %>">ペース判定：<%= pace[:label] %></p>
      <p class="text-sm text-gray-500 mt-0.5">
        残り <%= @certification.remaining_days %> 日　・　達成率 <%= @certification.achievement_rate %>%
      </p>
    </div>
  </div>

  <%# 🔴遅れ判定時の再計算メッセージ %>
  <% if @certification.pace_status == :behind %>
    <div class="bg-orange-50 border border-orange-200 rounded-lg p-4 mb-6 flex items-start gap-3">
      <span class="text-xl leading-none mt-0.5">💪</span>
      <p class="text-sm text-orange-800">
        今日から毎日
        <span class="font-bold text-lg"><%= @certification.daily_quota_minutes %></span>
        分学習すれば、試験日までに目標を達成できます！
      </p>
    </div>
  <% end %>

  <%# 今日のノルマ（大きく表示） %>
  <div class="bg-blue-50 border border-blue-200 rounded-lg p-6 mb-6 text-center">
    <p class="text-sm font-medium text-blue-600 mb-1">今日のノルマ</p>
    <p class="text-6xl font-extrabold text-blue-700 leading-none">
      <%= @certification.daily_quota_minutes %><span class="text-2xl font-semibold text-blue-500 ml-2">分</span>
    </p>
  </div>

  <%# 全体進捗バー %>
  <div class="bg-white rounded-lg shadow p-6 mb-6">
    <h2 class="text-sm font-semibold text-gray-700 mb-3">全体進捗</h2>
    <div class="flex justify-between text-sm text-gray-500 mb-2">
      <span>累計 <span class="font-medium text-gray-900"><%= @certification.total_studied_minutes %></span> 分</span>
      <span>目標 <span class="font-medium text-gray-900"><%= @certification.target_minutes %></span> 分</span>
    </div>
    <div class="w-full bg-gray-200 rounded-full h-4 overflow-hidden">
      <div class="bg-blue-500 h-4 rounded-full transition-all duration-500"
           style="width: <%= @certification.achievement_rate %>%"></div>
    </div>
    <p class="text-right text-xs text-gray-400 mt-1"><%= @certification.achievement_rate %>% 達成</p>
  </div>

  <%# 最近の記録（直近3件） %>
  <div class="bg-white rounded-lg shadow p-6 mb-6">
    <h2 class="text-sm font-semibold text-gray-700 mb-3">最近の記録</h2>
    <% if @recent_logs.present? %>
      <ul class="divide-y divide-gray-100">
        <% @recent_logs.each do |log| %>
          <li class="flex justify-between items-center py-2 text-sm">
            <span class="text-gray-500"><%= log.logged_on.strftime("%Y年%m月%d日") %></span>
            <span class="font-medium text-gray-900"><%= log.studied_minutes %> 分</span>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-gray-400 text-sm text-center py-2">まだ学習記録はありません。</p>
    <% end %>
  </div>

  <div class="flex flex-col gap-3">
    <%= link_to "学習を記録する", new_certification_study_log_path(@certification),
        class: "block w-full text-center bg-blue-600 text-white font-semibold py-3 px-6 rounded-md hover:bg-blue-700 transition" %>
    <%= link_to "記録履歴を見る", certification_study_logs_path(@certification),
        class: "block w-full text-center bg-white border border-gray-300 text-gray-700 font-semibold py-3 px-6 rounded-md hover:bg-gray-50 transition" %>
    <%= link_to "資格情報を編集する", edit_certification_path(@certification),
        class: "block w-full text-center bg-white border border-gray-300 text-gray-700 font-semibold py-3 px-6 rounded-md hover:bg-gray-50 transition" %>
  </div>
</div>
